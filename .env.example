# ============================================
# AI Travel Planner - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3002

# ============================================
# AI MODEL API KEYS
# ============================================
# OpenAI API Key (required for GPT-4)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key (required for Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# DeepSeek API Key (optional)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# ============================================
# RATE LIMITING
# ============================================
# Secret key to bypass rate limits (for admin/monitoring)
# Use: curl -H "X-Skip-Rate-Limit: your-secret-key"
RATE_LIMIT_BYPASS_KEY=your-very-secret-bypass-key-change-this

# ============================================
# SECURITY & CORS
# ============================================
# Comma-separated list of allowed origins
# Development: use * for local testing
# Production: specify exact domains
# Example: https://example.com,https://app.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# ============================================
# SENTRY ERROR MONITORING
# ============================================
# Create free account at https://sentry.io
# Leave empty to disable error monitoring
SENTRY_DSN=

# Sampling rate for performance tracing (0.0-1.0)
# 0.1 = sample 10% of requests (reduces cost)
# 1.0 = sample 100% of requests (more expensive)
SENTRY_TRACE_SAMPLE_RATE=0.1

# Enable debug logging for Sentry
SENTRY_DEBUG=false

# ============================================
# EXTERNAL SERVICES (Optional)
# ============================================
# Base URL for external APIs if needed
EXTERNAL_API_BASE_URL=

# ============================================
# DATABASE (Future - Phase 3)
# ============================================
# PostgreSQL connection (for Phase 3 persistence)
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_travel_planner

# ============================================
# LOGGING (Optional)
# ============================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# ============================================
# FEATURE FLAGS (Optional)
# ============================================
# Enable/disable features for testing
FEATURE_ENABLE_SENTRY=true
FEATURE_ENABLE_RATE_LIMITING=true
FEATURE_ENABLE_VALIDATION=true
